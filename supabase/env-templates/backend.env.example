# EONS backend env template - placeholders only

# Copy this locally to .env only when deploying privately.
# Never commit real secrets.

SUPABASE_URL=PLACEHOLDER_SET_IN_BACKEND_RUNTIME
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SET_IN_BACKEND_RUNTIME_ONLY
EONS_CORS_ORIGIN=https://esteshrrman99-commits.github.io
EONS_PRODUCTION_MODE=false
EONS_AUTH_ENABLED=false
EONS_ENCRYPTION_ENABLED=false
EONS_UPLOADS_ENABLED=false
EONS_REVIEW_ENABLED=false
EONS_OWNER_APPROVAL=false
EONS_STORAGE_BUCKET=eons-evidence-vault
EONS_BACKUP_BUCKET=PLACEHOLDER_SET_IN_BACKEND_RUNTIME
